<Window x:Class="LSAnalyzer.Views.BatchAnalyze"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LSAnalyzer.Views"
        xmlns:ViewModels="clr-namespace:LSAnalyzer.ViewModels"
        xmlns:converter="clr-namespace:LSAnalyzer.ViewModels.ValueConverter"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=ViewModels:BatchAnalyze, IsDesignTimeCreatable=True}"
        x:Name="windowBatchAnalyze"
        Closing="Window_Closing"
        Title="Batch analyze" MinHeight="600" MinWidth="800" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <sys:Boolean x:Key="BooleanTrue">True</sys:Boolean>
        <converter:BoolToVisibility x:Key="BoolToVisibilityConverter"/>
        <converter:InverseBool x:Key="InverseBoolConverter"/>
        <converter:LeftSideFileName x:Key="LeftSideFileNameConverter"/>
        <local:WindowSettings x:Key="WindowSettings"/>
        <DataTemplate x:Key="SuccessTemplate" DataType="{x:Type ViewModels:BatchAnalyze+BatchEntry}">
            <StackPanel VerticalAlignment="Center">
                <fa:IconImage Icon="Slash" Foreground="Gray" Width="16" Visibility="{Binding WasIgnored, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter={StaticResource BooleanTrue}}"/>
                <fa:IconImage Icon="Check" Foreground="Green" Width="18" Visibility="{Binding IsSuccess, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter={StaticResource BooleanTrue}}"/>
                <fa:IconImage Icon="Xmark" Foreground="Red" Width="16" Visibility="{Binding IsFail, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter={StaticResource BooleanTrue}}"/>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>
    <Window.Width>
        <Binding Source="{StaticResource WindowSettings}" Path="WidthBatchAnalyze" Mode="TwoWay"/>
    </Window.Width>
    <Window.Height>
        <Binding Source="{StaticResource WindowSettings}" Path="HeightBatchAnalyze" Mode="TwoWay"/>
    </Window.Height>
    <Window.IsEnabled>
        <Binding Path="IsBusy" Converter="{StaticResource InverseBoolConverter}"/>
    </Window.IsEnabled>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">Recent:</TextBlock>
        <Border Grid.Row="0" Grid.Column="1" Margin="10,0,0,0" x:Name="BorderRecent">
            <ComboBox ItemsSource="{Binding RecentBatchAnalyzeFiles, Converter={StaticResource LeftSideFileNameConverter}}" SelectedItem="{Binding SelectedRecentBatchAnalyzeFile}" Width="{Binding ElementName=BorderRecent, Path=ActualWidth}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource LeftSideFileNameConverter}}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </Border>
        <TextBlock Grid.Row="1" Grid.Column="0" Text="File:" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,10,0,0"/>
        <Border Grid.Row="1" x:Name="borderTextBoxFileName" Grid.Column="1" Margin="10,10,0,0" >
            <TextBox x:Name="textBoxFileName" HorizontalAlignment="Stretch" TextWrapping="NoWrap" Text="{Binding FileName, Converter={StaticResource LeftSideFileNameConverter}}" IsEnabled="False" Height="22" MaxWidth="{Binding ElementName=borderTextBoxFileName, Path=ActualWidth}"/>
        </Border>
        <Button Grid.Row="1" x:Name="buttonSelectFile" Grid.Column="2" Content="Select ..." HorizontalAlignment="Left" Margin="10,10,0,0" Width="80" Height="22" Click="ButtonSelectFile_Click"/>
        <Button Grid.Row="2" Grid.Column="2" Content="Load" HorizontalAlignment="Left" Margin="10,10,0,0" Width="80" Height="22" Command="{Binding LoadBatchFileCommand}" IsEnabled="{Binding ElementName=textBoxFileName, Path=Text.Length}"/>
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Target:" HorizontalAlignment="Left" Margin="0,10,0,0" VerticalAlignment="Top"/>
        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Vertical" Margin="10,10,0,0">
            <RadioButton x:Name="radioButtonTargetReload" Content="Reload files specified in file" HorizontalAlignment="Left" VerticalAlignment="Top" GroupName="Target" IsChecked="{Binding UseCurrentFile, Converter={StaticResource InverseBoolConverter}}"/>
            <RadioButton x:Name="radioButtonTargetCurrent" Content="Current file for analyses" HorizontalAlignment="Left" Height="15" GroupName="Target" IsChecked="{Binding UseCurrentFile}" IsEnabled="{Binding HasCurrentFile}"/>
        </StackPanel>
        <Button Grid.Row="3" Grid.Column="2" Content="Analyze" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,10,0,0" Height="22" Width="80" Command="{Binding RunBatchCommand}" IsEnabled="{Binding AnalysesTable.Count}"/>
        <Border x:Name="dataGridWidthHelper" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,10,0,0" >
            <DataGrid x:Name="dataGridBatchResults" Width="{Binding Path=ActualWidth, ElementName=dataGridWidthHelper}" ItemsSource="{Binding AnalysesTable}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" CanUserReorderColumns="False" CanUserResizeRows="False" CanUserSortColumns="False">
                <DataGrid.Resources>
                    <Style x:Key="DataGridCenteredText" TargetType="TextBlock">
                        <Setter Property="VerticalAlignment" Value="Center" />
                        <Setter Property="HorizontalAlignment" Value="Center" />
                    </Style>
                    <Style x:Key="DataGridCenteredCheckBox" TargetType="CheckBox">
                        <Setter Property="VerticalAlignment" Value="Center" />
                        <Setter Property="HorizontalAlignment" Value="Center" />
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nr." Binding="{Binding Id}" ElementStyle="{StaticResource DataGridCenteredText}" IsReadOnly="True"/>
                    <DataGridCheckBoxColumn Header="Select" Binding="{Binding Selected, UpdateSourceTrigger=PropertyChanged}" ElementStyle="{StaticResource DataGridCenteredCheckBox}"/>
                    <DataGridTextColumn Header="Analysis" Binding="{Binding Analysis.Analysis.ShortInfo}" Width="300" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style>
                                <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="Success" CellTemplate="{StaticResource SuccessTemplate}" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Info" Binding="{Binding Message}" Width="300" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style>
                                <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
        <Button Grid.Row="5" Grid.Column="2" Content="OK" HorizontalAlignment="Left" Margin="10,10,0,0" Height="22" Width="80" Command="{Binding TransferResultsCommand}" CommandParameter="{Binding ElementName=windowBatchAnalyze}" IsEnabled="{Binding FinishedAllCalculations}"/>
    </Grid>
</Window>
