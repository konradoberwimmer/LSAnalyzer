<UserControl x:Class="LSAnalyzer.Views.CustomControls.VirtualVariable.VirtualVariableRecode"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:LSAnalyzer.Views.CustomControls.VirtualVariable"
             xmlns:models="clr-namespace:LSAnalyzer.Models"
             xmlns:converter="clr-namespace:LSAnalyzer.ViewModels.ValueConverter"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:dd="clr-namespace:GongSolutions.Wpf.DragDrop;assembly=GongSolutions.Wpf.DragDrop"
             xmlns:customControls="clr-namespace:LSAnalyzer.Views.CustomControls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=models:VirtualVariableRecode, IsDesignTimeCreatable=True}"
             d:DesignHeight="300" d:DesignWidth="400">
    <UserControl.Resources>
        <customControls:DropHandlerVariable x:Key="DropHandlerVariable"/>
        <sys:Boolean x:Key="BooleanTrue">True</sys:Boolean>
        <converter:BoolToVisibility x:Key="BoolToVisibilityConverter"/>
        <converter:InverseBool x:Key="InverseBoolConverter"/>
        <ObjectDataProvider x:Key="EnumElseActionDataSource"
                            ObjectType="{x:Type sys:Enum}"
                            MethodName="GetValues">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:VirtualVariableRecode+ElseAction" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="EnumTermTypeDataSource"
                            ObjectType="{x:Type sys:Enum}"
                            MethodName="GetValues">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:VirtualVariableRecode+Term+TermType" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <Style x:Key="InvisibleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid Background="{TemplateBinding Background}">
                            <ContentPresenter Content="{TemplateBinding Content}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto" MinWidth="200"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" MinHeight="22"/>
                <RowDefinition Height="Auto" MinHeight="22"/>
                <RowDefinition Height="Auto" MinHeight="35"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ContentControl Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" dd:DragDrop.IsDropTarget="True" dd:DragDrop.DropHandler="{StaticResource DropHandlerVariable}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <ContentControl ContentTemplate="{StaticResource InfoTipInline}"/>
                    <TextBlock VerticalAlignment="Center" Margin="5,0,0,0">To add a variable, double-click it or drag it here.</TextBlock>
                </StackPanel>
            </ContentControl>
            <StackPanel Grid.Row="1" Grid.Column="1" Height="22" Margin="5,5,0,0" Orientation="Horizontal">
                <ItemsControl ItemsSource="{Binding Variables}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="195">
                                <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button Background="Transparent" BorderBrush="Transparent" Margin="5,0,0,0" Padding="0" VerticalAlignment="Center" Visibility="{Binding CanAddRule, Converter={StaticResource BoolToVisibilityConverter}}" Click="ButtonRemoveLastVariable_Click">
                    <Button.Content>
                        <fa:IconImage Icon="CircleXmark" Height="15" Foreground="Red"/>
                    </Button.Content>
                </Button>
            </StackPanel>
            <TextBlock Grid.Row="1" Grid.Column="2" Margin="5,5,0,0" VerticalAlignment="Center" Text="Result"/>
            <Rectangle Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Height="1" Margin="0,5,0,0" Stroke="Gray" VerticalAlignment="Top"/>
            <ItemsControl Grid.Row="2" Grid.Column="0" Margin="0,10,0,0" ItemsSource="{Binding Rules}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Height="25">
                            <Button Background="Transparent" BorderBrush="Transparent" Padding="0" VerticalAlignment="Center" Click="ButtonRemoveRule_OnClick">
                                <Button.Content>
                                    <fa:IconImage Icon="CircleXmark" Height="15" Foreground="Red"/>
                                </Button.Content>
                            </Button>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <ItemsControl Grid.Row="2" Grid.Column="1" Margin="5,10,0,0" ItemsSource="{Binding Rules}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ItemsControl ItemsSource="{Binding Criteria}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Height="25"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Width="195" Orientation="Horizontal">
                                        <ComboBox Width="75" Height="22" ItemsSource="{Binding Source={StaticResource EnumTermTypeDataSource}}" SelectedItem="{Binding Type}"/>
                                        <TextBox Margin="5,0,0,0" Width="50" Height="22" Text="{Binding Value}" Visibility="{Binding ValueMakesSense, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <TextBox Margin="5,0,0,0" Width="50" Height="22" Text="{Binding MaxValue}" Visibility="{Binding MaxValueMakesSense, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <ItemsControl Grid.Row="2" Grid.Column="2" Margin="5,10,0,0" ItemsSource="{Binding Rules}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Height="25" Orientation="Horizontal">
                            <TextBox Width="75" Height="22" VerticalAlignment="Center" Text="{Binding ResultValue}" IsEnabled="{Binding ResultNa, Converter={StaticResource InverseBoolConverter}}"/>
                            <CheckBox Margin="5,0,0,0" VerticalAlignment="Center" IsChecked="{Binding ResultNa}" Content="Missing"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Rectangle Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Height="1" Margin="0,5,0,0" Stroke="Gray" VerticalAlignment="Top"/>
            <Button Grid.Row="3" Grid.Column="0" Style="{StaticResource InvisibleButtonStyle}" Margin="2,10,0,0" Padding="0" VerticalAlignment="Center" HorizontalAlignment="Right" IsEnabled="{Binding Variables.Count}" Click="ButtonAddRule_OnClick">
                <Button.Content>
                    <StackPanel>
                        <fa:IconImage Icon="CirclePlus" Height="15" Foreground="Green" Visibility="{Binding CanAddRule, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter={StaticResource BooleanTrue}}"/>
                        <fa:IconImage Icon="CirclePlus" Height="15" Foreground="Gray" Visibility="{Binding CannotAddRule, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter={StaticResource BooleanTrue}}"/>
                    </StackPanel>
                </Button.Content>
            </Button>
            <TextBlock Grid.Row="3" Grid.Column="1" Text="add rule" Margin="5,10,0,0" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="3" Grid.Column="1" Margin="5,10,0,0" VerticalAlignment="Center" HorizontalAlignment="Right" Text="Else"/>
            <ComboBox Grid.Row="3" Grid.Column="2" Margin="5,10,0,0" Width="75" HorizontalAlignment="Left" ItemsSource="{Binding Source={StaticResource EnumElseActionDataSource}}" SelectedItem="{Binding Else}" IsEnabled="{Binding ElseCopyMakesSense}"/>
        </Grid>
    </ScrollViewer>
</UserControl>
