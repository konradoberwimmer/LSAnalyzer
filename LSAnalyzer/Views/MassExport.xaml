<Window x:Class="LSAnalyzer.Views.MassExport"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        xmlns:converter="clr-namespace:LSAnalyzer.ViewModels.ValueConverter"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:viewModels="clr-namespace:LSAnalyzer.ViewModels"
        xmlns:local="clr-namespace:LSAnalyzer.Views"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=viewModels:MassExport, IsDesignTimeCreatable=True}"
        x:Name="WindowMassExport"
        Title="Mass export" MinWidth="800" SizeToContent="WidthAndHeight" ResizeMode="NoResize" Closed="Window_OnClosed" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <converter:BoolToVisibility x:Key="BoolToVisibilityConverter"/>
        <converter:InverseBool x:Key="InverseBoolConverter"/>
    </Window.Resources>
    <Window.IsEnabled>
        <Binding Path="IsBusy" Converter="{StaticResource InverseBoolConverter}"/>
    </Window.IsEnabled>
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">Folder:</TextBlock>
        <Border Grid.Row="0" Grid.Column="1" x:Name="BorderTextBoxFolder" Margin="5,0,0,0" HorizontalAlignment="Stretch">
            <TextBox Height="22" Width="{Binding ElementName=BorderTextBoxFolder, Path=ActualWidth}" IsEnabled="False" Text="{Binding Folder, Mode=OneWay}"/>
        </Border>
        <Button Grid.Row="0" Grid.Column="2" Height="22" Width="80" Margin="5,0,0,0" Content="Select ..." Click="ButtonSelect_OnClick"/>
        
        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,5,0,0" VerticalAlignment="Center">Filename prefix:</TextBlock>
        <Border Grid.Row="1" Grid.Column="1" x:Name="BorderTextBoxPrefix" Margin="5,5,0,0" HorizontalAlignment="Stretch">
            <TextBox Height="22" Width="{Binding ElementName=BorderTextBoxPrefix, Path=ActualWidth}" Text="{Binding Prefix, UpdateSourceTrigger=PropertyChanged}"/>
        </Border>
        
        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,5,0,0" VerticalAlignment="Center">Export type:</TextBlock>
        <ComboBox Grid.Row="2" Grid.Column="1" Margin="5,5,0,0" Width="Auto" HorizontalAlignment="Left" Height="22" ItemsSource="{Binding ExportTypes}" DisplayMemberPath="DisplayName" SelectedValue="{Binding SelectedExportType}"/>
        
        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,5,0,0" VerticalAlignment="Center">Single excel file:</TextBlock>
        <CheckBox Grid.Row="3" Grid.Column="1" Margin="5,5,0,0" Height="22" VerticalContentAlignment="Center" IsEnabled="{Binding CanSingleExcelFile}" IsChecked="{Binding SingleExcelFile}"/>
        
        <Button Grid.Row="4" Grid.Column="2" Margin="5,5,0,0" Height="22" Width="80" Content="Export" IsEnabled="{Binding CanExport}" Command="{Binding ExportCommand}" CommandParameter="{Binding ElementName=WindowMassExport}"/>
        
        <fa:IconImage Grid.Row="0" Grid.Column="0" Grid.RowSpan="5" Grid.ColumnSpan="3" Icon="Sun" fa:Awesome.Spin="True" VerticalAlignment="Center" Height="80" Foreground="Gray" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
    </Grid>
</Window>
