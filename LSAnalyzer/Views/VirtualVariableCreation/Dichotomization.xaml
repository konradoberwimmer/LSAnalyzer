<Window x:Class="LSAnalyzer.Views.VirtualVariableCreation.Dichotomization"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:LSAnalyzer.Views.VirtualVariableCreation"
        xmlns:viewmodels="clr-namespace:LSAnalyzer.ViewModels.VirtualVariableCreation"
        xmlns:converter="clr-namespace:LSAnalyzer.ViewModels.ValueConverter"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=viewmodels:Dichotomization, IsDesignTimeCreatable=True}"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Title="Dichotomization" SizeToContent="Height" Width="400" x:Name="WindowDichotomization">
    <Window.Resources>
        <sys:Boolean x:Key="BooleanTrue">True</sys:Boolean>
        <converter:BoolToVisibility x:Key="BoolToVisibilityConverter"/>
        <converter:DictionaryHasElementToBool x:Key="DictionaryHasElementToBoolConverter"/>
        <converter:NullToBool x:Key="NullToBoolConverter"/>
        <ObjectDataProvider x:Key="EnumReferenceCategoryTypeDataSource"
                            ObjectType="{x:Type sys:Enum}"
                            MethodName="GetValues">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="viewmodels:Dichotomization+ReferenceCategoryType" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">Variable:</TextBlock>
        <TextBlock Grid.Row="1" Grid.Column="1" Foreground="Red" Margin="5,0,0,0" Visibility="{Binding ShowCategoryCountError, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter={StaticResource BooleanTrue}}">Too many categories (>20).</TextBlock>
        <ComboBox Grid.Row="0" Grid.Column="1" Margin="5,0,0,0" ItemsSource="{Binding Variables}" SelectedItem="{Binding SelectedVariable}" DisplayMemberPath="Info"/>
        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,5,0,0">Reference:</TextBlock>
        <ComboBox Grid.Row="2" Grid.Column="1" Margin="5,5,0,0" Width="120" HorizontalAlignment="Left" ItemsSource="{Binding Source={StaticResource EnumReferenceCategoryTypeDataSource}}" SelectedItem="{Binding ReferenceCategory}"/>
        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,5,0,0">Category:</TextBlock>
        <ComboBox Grid.Row="3" Grid.Column="1" Margin="5,5,0,0" Width="120" HorizontalAlignment="Left" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" IsEnabled="{Binding CategoriesMakesSense}"/>
        <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="0,5,0,0">Prefix:</TextBlock>
        <TextBox Grid.Row="4" Grid.Column="1" Margin="5,5,0,0" Height="22" Text="{Binding Prefix, UpdateSourceTrigger=PropertyChanged}">
            <ToolTipService.ToolTip>
                <TextBlock Text="{Binding Errors[Prefix], FallbackValue=...}" Foreground="Red"/>
            </ToolTipService.ToolTip>
            <ToolTipService.IsEnabled>
                <Binding Path="Errors" Converter="{StaticResource ResourceKey=DictionaryHasElementToBoolConverter}" ConverterParameter="Prefix"/>
            </ToolTipService.IsEnabled>
        </TextBox>
        <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Margin="0,5,0,0">Label:</TextBlock>
        <TextBox Grid.Row="5" Grid.Column="1" Margin="5,5,0,0" Height="22" Text="{Binding NewLabel, UpdateSourceTrigger=PropertyChanged}">
            <ToolTipService.ToolTip>
                <TextBlock Text="{Binding Errors[NewLabel], FallbackValue=...}" Foreground="Red"/>
            </ToolTipService.ToolTip>
            <ToolTipService.IsEnabled>
                <Binding Path="Errors" Converter="{StaticResource ResourceKey=DictionaryHasElementToBoolConverter}" ConverterParameter="NewLabel"/>
            </ToolTipService.IsEnabled>
        </TextBox>
        <Button Grid.Row="6" Grid.Column="1" Height="22" Width="80" HorizontalAlignment="Right" Margin="5,5,0,0" Content="Create" IsEnabled="{Binding SelectedVariable, Converter={StaticResource NullToBoolConverter}}" Command="{Binding CreateDichotomizationCommand}" CommandParameter="{Binding ElementName=WindowDichotomization}"/>
    </Grid>
</Window>
