<Window x:Class="LSAnalyzer.Views.SystemSettings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LSAnalyzer.Views"
        xmlns:viewModels="clr-namespace:LSAnalyzer.ViewModels"
        xmlns:converter="clr-namespace:LSAnalyzer.ViewModels.ValueConverter"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=viewModels:SystemSettings, IsDesignTimeCreatable=True}"
        x:Name="windowSystemSettings" Title="System information" Height="700" MinHeight="600" Width="600" MinWidth="350" WindowStartupLocation="CenterScreen" Closing="SystemSettings_OnClosing">
    <Window.Resources>
        <converter:BooleanAnd x:Key="BooleanAndConverter"/>
        <converter:EmptyStringTo x:Key="EmptyStringToConverter"/>
        <converter:IntegerToStringLenient x:Key="IntegerToStringLenientConverter"/>
        <viewModels:AnalysisPresentation x:Key="AnalysisPresentation"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <GroupBox Grid.Row="0" Margin="10" Padding="5">
            <GroupBox.Header>
                <TextBlock FontWeight="Bold" Text="{Binding Version, StringFormat=LSAnalyzer v{0}}"/>
            </GroupBox.Header>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3">
                     by Konrad Oberwimmer, released under 
                    <Hyperlink x:Name="hyperLinkGPL3" NavigateUri="https://www.gnu.org/licenses/gpl-3.0.html" RequestNavigate="HyperLinkGPL3_RequestNavigate">
                        GPL-3
                    </Hyperlink>
                </TextBlock>
                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,5,0,0" Text="{Binding CountConfiguredDatasetTypes, StringFormat={}{0} configured dataset types ...}"/>
                <Button x:Name="buttonLoadDefaultDatasetConfiguration" Grid.Row="1" Grid.Column="2" Margin="0,5,0,0" Width="80" Height="22" Content="Load default" HorizontalAlignment="Right" Click="ButtonLoadDefaultDatasetConfiguration_Click"/>
                <Rectangle Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Height="1" Stroke="Gray" VerticalAlignment="Top" Margin="0,5,0,0"/>
                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,5,0,0" Text="Dataset type repository URL:"/>
                <TextBox Grid.Row="4" Grid.Column="0" Margin="0,5,0,0" Text="{Binding RepositoryUrl, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Margin="5,5,0,0" Text="Collection:"/>
                <TextBox Grid.Row="4" Grid.Column="1" Margin="5,5,0,0" Text="{Binding CollectionName, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                <Button Grid.Row="4" Grid.Column="2" Margin="5,5,0,0" Content="Fetch new" Width="80" Height="22" Command="{Binding FetchDatasetTypesCommand}">
                    <Button.IsEnabled>
                        <MultiBinding Converter="{StaticResource BooleanAndConverter}">
                            <Binding Path="RepositoryUrl.Length"/>
                            <Binding Path="CollectionName.Length"/>
                        </MultiBinding>
                    </Button.IsEnabled>
                </Button>
            </Grid>            
        </GroupBox>
        <GroupBox Grid.Row="2" Margin="10,0,10,10" Padding="5">
            <GroupBox.Header>
                <TextBlock FontWeight="Bold" Text="R / BIFIEsurvey"/>
            </GroupBox.Header>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">Custom R installation:</TextBlock>
                <Border Grid.Row="0" Grid.Column="1" Margin="5,0,0,0" x:Name="BorderTextBoxAlternativeRLocation" HorizontalAlignment="Stretch">
                    <TextBox Width="{Binding ElementName=BorderTextBoxAlternativeRLocation, Path=ActualWidth}" IsEnabled="False" Text="{Binding AlternativeRLocation}"/>
                </Border>
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="5,0,0,0" Orientation="Horizontal" HorizontalAlignment="Right" >
                    <Button Height="22" Width="80" IsEnabled="{Binding AlternativeRLocation, Converter={StaticResource EmptyStringToConverter}, ConverterParameter=false, FallbackValue=true}" Click="ButtonClearRLocation_OnClick" ToolTip="Use user or machine default R installation.">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock>Clear</TextBlock>
                                <ContentControl ContentTemplate="{StaticResource InfoTipInline}"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    <Button Height="22" Width="80" Margin="5,0,0,0" Content="Select ..." Click="ButtonSelectRLocation_OnClick"/>
                </StackPanel>
                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,5,0,5" Text="{Binding RVersion}"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Left" VerticalAlignment="Center" Text="{Binding BifieSurveyVersion, StringFormat={}BIFIEsuvey version: {0}}" Margin="0,5,5,0"/>
                <Button Grid.Row="2" Grid.Column="2" HorizontalAlignment="Right" Content="{Binding BIFIEsurveyButtonTitle}" Height="22" Width="80" Command="{Binding UpdateBifieSurveyCommand}" IsEnabled="{Binding ConnectedToR}"/>
            </Grid>
        </GroupBox>
        <GroupBox Grid.Row="1" Margin="10,0,10,10" Padding="5">
            <GroupBox.Header>
                <TextBlock FontWeight="Bold" Text="Settings"/>
            </GroupBox.Header>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" IsChecked="{Binding ShowLabelsDefault}">Show variable/value labels by default</CheckBox>
                <Rectangle Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Height="1" Stroke="Gray" VerticalAlignment="Top" Margin="0,5,0,0"/>
                <CheckBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,10,0,0" IsChecked="{Binding ConfirmRemovingAnalysis}">Show confirmation dialog before removing an analysis</CheckBox>
                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,5,0,0" VerticalAlignment="Center">Default analysis export type:</TextBlock>
                <ComboBox Grid.Row="2" Grid.Column="1" Margin="5,5,0,0" ItemsSource="{Binding Source={StaticResource AnalysisPresentation}, Path=ExportTypes, Mode=OneTime}" DisplayMemberPath="DisplayName" SelectedItem="{Binding DefaultExportType}"/>
                <Rectangle Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Height="1" Stroke="Gray" VerticalAlignment="Top" Margin="0,5,0,0"/>
                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,10,0,0">Number of recent files (per file system / data provider):</TextBlock>
                <TextBox Grid.Row="3" Grid.Column="1" Width="40" HorizontalAlignment="Left" Margin="5,10,0,0" TextAlignment="Right" Text="{Binding NumberRecentFiles, Converter={StaticResource IntegerToStringLenientConverter}, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,5,0,0">Number of recent subsetting expressions (per dataset type):</TextBlock>
                <TextBox Grid.Row="4" Grid.Column="1" Width="40" HorizontalAlignment="Left" Margin="5,5,0,0" TextAlignment="Right" Text="{Binding NumberRecentSubsettingExpressions, Converter={StaticResource IntegerToStringLenientConverter}, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Row="5" Grid.Column="1" HorizontalAlignment="Right" Width="80" Content="Save" Command="{Binding SaveSettingsCommand}" IsEnabled="{Binding IsChanged}"/>
            </Grid>
        </GroupBox>
        <GroupBox Grid.Row="3" Margin="10,0,10,10" Padding="5">
            <GroupBox.Header>
                <TextBlock FontWeight="Bold" Text="Session Log"/>
            </GroupBox.Header>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <DataGrid Grid.Row="0" ItemsSource="{Binding SessionLog, Mode=OneTime}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time" Binding="{Binding When}"/>
                        <DataGridTextColumn Header="Analysis" Binding="{Binding AnalysisName}"/>
                        <DataGridTextColumn Header="R code" Binding="{Binding RcodeForTableCell}"/>
                    </DataGrid.Columns>
                </DataGrid>
                <StackPanel Grid.Row="1" Margin="0,5,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="buttomSaveSessionRcode" Content="Save R code (.R) ..." Height="22" Width="100" Margin="0,0,10,0" Click="ButtonSaveSessionRcode_Click"/>
                    <Button x:Name="buttomSaveSessionLog" Content="Save All (.txt) ..." Height="22" Width="100" Click="ButtonSaveSessionLog_Click"/>
                </StackPanel>
            </Grid>
        </GroupBox>
    </Grid>
</Window>
